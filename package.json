{
  "name": "react-native-omni-select",
  "version": "1.1.0",
  "description": "The omni-platform select component for React Native - iOS, Android, Web, Expo, Next.js SSR",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "sideEffects": false,
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "typecheck:example": "tsc --noEmit -p tsconfig.example.json",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "prepare": "bob build",
    "prepublishOnly": "bun run typecheck && bun run lint && jest && bob build"
  },
  "keywords": [
    "react-native",
    "dropdown",
    "select",
    "picker",
    "multiselect",
    "autocomplete",
    "expo",
    "react-native-web",
    "nextjs",
    "ssr",
    "universal",
    "cross-platform",
    "ios",
    "android",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anivar/react-native-omni-select.git"
  },
  "author": "Anivar Aravind <ping@anivar.net>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/anivar/react-native-omni-select/issues"
  },
  "homepage": "https://github.com/anivar/react-native-omni-select#readme",
  "funding": "https://github.com/sponsors/anivar",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@react-native/babel-preset": "^0.85.2",
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "jest": "^30.3.0",
    "react": "^19.1.0",
    "react-native": "0.85.2",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "react-native-web": {
      "optional": true
    }
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
